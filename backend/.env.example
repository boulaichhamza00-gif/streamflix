# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/streamflix

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

